// Prisma schema for Lab 2 — Server & Client Components
// Uses Railway PostgreSQL as the datasource (connection string comes from .env)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
}

model Product {
  id         Int      @id @default(autoincrement())
  name       String
  price      Float
  stock      Int      @default(0)
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
}